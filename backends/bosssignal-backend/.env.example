# BossSignal backend environment variables
# Copy this to .env and fill in your values.
# Never commit .env to git.

# ── Auth ──────────────────────────────────────────────────────
# Must exactly match BossSignalConfig.SHARED_SECRET in your Enforce mod.
# The backend refuses authenticated requests while this is left at CHANGE_ME.
# Generate a strong secret: openssl rand -hex 32
# The secret is sent ONLY via the X-BossSignal-Secret header (never ?secret=).
BOSSSIGNAL_SECRET=CHANGE_ME

# When false (default), the read endpoints that power the browser dashboard
# (bosses, trophies, servers, events list/SSE, kb) stay open with no secret.
# Set to true to ALSO require the X-BossSignal-Secret header on those reads
# (defence-in-depth; only do this if your dashboard supplies the header).
# The write path (POST /api/v1/events) always requires the secret.
REQUIRE_READ_AUTH=false

# ── Database ──────────────────────────────────────────────────
# If using docker-compose, the default below works as-is.
# If using an external Postgres, set your connection string here.
DATABASE_URL=postgresql+asyncpg://bosssignal:bosssignal@db:5432/bosssignal

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── Debug ─────────────────────────────────────────────────────
# Set to false in production — disables SQL echo and verbose logging
DEBUG=false

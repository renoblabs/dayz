# HiveAPI environment configuration -- EXAMPLE / template.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must NEVER be committed. The values below are safe placeholders, not secrets.

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# One of: dev | test | production
# - dev/test: enables local-only shortcuts (e.g. the server-login proof bypass
#   when REQUEST_SIGNATURE_REQUIRED=false). Use for local development only.
# - production: all insecure shortcuts are disabled regardless of other flags.
ENV=dev

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Require request signatures / proof verification on server endpoints.
# MUST be true in production. The dev login shortcut only works when this is
# false AND ENV is dev/test. Default is true (secure).
REQUEST_SIGNATURE_REQUIRED=true

# Secret used to sign and verify issued JWTs (HS256). REQUIRED -- the API
# refuses to issue tokens while this is unset. Generate a long random value,
# e.g.  openssl rand -hex 32
# Do NOT use this placeholder in any real deployment.
JWT_SIGNING_SECRET=change-me-to-a-long-random-secret

# ---------------------------------------------------------------------------
# Admin (HTTP Basic auth for admin endpoints)
# ---------------------------------------------------------------------------
# Admin auth fails CLOSED (403) when ADMIN_PASSWORD is empty/unset.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-admin-password

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins. '*' allows any origin (credentialed
# requests are auto-disabled in that case). Set explicit origins in production,
# e.g. CORS_ORIGINS=https://dashboard.example.com,https://admin.example.com
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Seeding
# ---------------------------------------------------------------------------
# When true, the entrypoint seeds demo data on startup. Keep this FALSE in
# production -- demo seed data includes well-known sample servers/credentials.
AUTO_SEED=false

# ---------------------------------------------------------------------------
# Infrastructure (override per environment)
# ---------------------------------------------------------------------------
# DB_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hive
# REDIS_URL=redis://localhost:6379/0
